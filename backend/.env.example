# Social Media Platform Credentials
# Get these from the respective developer portals

# Supabase Connection
DATABASE_URL="postgres://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:6543/postgres?pgbouncer=true"
DIRECT_URL="postgres://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres"

# Auth
JWT_SECRET="generate-a-long-random-string-here"
PORT=3000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# Redis (for BullMQ)
REDIS_URL="redis://localhost:6379"

# Twitter API v2
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=
TWITTER_CALLBACK_URL=http://localhost:3000/api/auth/twitter/callback

# Instagram / Facebook (Meta)
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_CALLBACK_URL=http://localhost:3000/api/auth/facebook/callback

# LinkedIn
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_CALLBACK_URL=http://localhost:3000/api/auth/linkedin/callback

# TikTok
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_CALLBACK_URL=http://localhost:3000/api/auth/tiktok/callback

# YouTube (Google)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback

# Pinterest
PINTEREST_APP_ID=
PINTEREST_APP_SECRET=
PINTEREST_CALLBACK_URL=http://localhost:3000/api/auth/pinterest/callback

# Media Storage (Cloudflare R2 / S3)
R2_ACCOUNT_ID=
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_BUCKET_NAME=socialpulse-media
